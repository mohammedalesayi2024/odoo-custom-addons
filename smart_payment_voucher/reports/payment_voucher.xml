<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_payment_voucher"
            model="ir.actions.report">

        <field name="name">
            Payment Voucher
        </field>

        <field name="model">
            account.payment
        </field>

        <field name="report_type">
            qweb-pdf
        </field>

        <field name="report_name">
            smart_payment_voucher.payment_voucher_template
        </field>

        <field name="report_file">
            smart_payment_voucher.payment_voucher_template
        </field>

        <field name="print_report_name">
            'Payment Voucher - %s' % (object.name)
        </field>

    </record>

</odoo>