<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="payment_voucher_template">

        <t t-call="web.html_container">

            <t t-foreach="docs" t-as="o">

                 <t t-call="web.basic_layout">
                    <div class="page"
                      style="
                              direction:rtl;
                              font-family:Tahoma;
                              margin-top:0px;">

                        <!-- Company Header -->

                        <table style="
       width:100%;
       border:1px solid #dcdcdc;
       border-collapse:collapse;
       margin-bottom:20px;">

    <tr>

        <td style="
            width:20%;
            text-align:center;
            padding:3px;
            border-left:1px solid #dcdcdc;">

            <img t-if="o.company_id.logo"
                 t-att-src="image_data_uri(o.company_id.logo)"
                 style="max-height:60px; max-width:80px;"/>

        </td>

        <td style="
            width:85%;
            text-align:right;
            padding:5px;">

            <h2 style="
                margin:0;
                color:#1f2d3d;">
                <span t-field="o.company_id.name"/>
            </h2>

            <div style="margin-top:8px;">
                جدة - المملكة العربية السعودية
            </div>

            <div t-if="o.company_id.vat">
                الرقم الضريبي:
                <span t-field="o.company_id.vat"/>
            </div>

            <div t-if="o.company_id.phone">
                هاتف:
                <span t-field="o.company_id.phone"/>
            </div>

            <div t-if="o.company_id.email">
                بريد:
                <span t-field="o.company_id.email"/>
            </div>

        </td>

    </tr>

</table>

                        <!-- Title -->

                      

                        <!-- Voucher Info -->

  <table style="width:100%; border-collapse:collapse; margin-bottom:20px;">

       <tr>

           <td style="width:60%;">

             <div style="
                background:#8b1e2d;
                color:white;
                text-align:center;
                font-size:24px;
                font-weight:bold;
                padding:20px;
                border-radius:6px;">

                سند صرف
  
               </div>

        </td>

        <td style="width:40%;">

          <table style="
                   width:100%;
                   border-collapse:collapse;">

                <tr>

                    <td style="border:1px solid #ccc;padding:8px;">
                        رقم السند
                    </td>

                    <td style="border:1px solid #ccc;padding:8px;">
                        <span t-field="o.name"/>
                    </td>

                </tr>

                <tr>

                    <td style="border:1px solid #ccc;padding:8px;">
                        التاريخ
                    </td>

                    <td style="border:1px solid #ccc;padding:8px;">
                        <span t-field="o.date"/>
                    </td>

                </tr>

            </table>
            
            

        </td>

    </tr>

</table>
<hr style="border:1px solid #e5e5e5; margin:10px 0 20px 0;"/>
                        <!-- Beneficiary -->

                        <div style="
                             background:#8b1e2d;
                             color:white;
                             padding:8px;
                             margin-bottom:10px;">

                            بيانات المستفيد

                        </div>

                        <table style="
                               width:100%;
                               border-collapse:collapse;
                               margin-bottom:20px;">

                            <tr>

                                <td style="border:1px solid #ccc;padding:8px;">
                                    المستفيد
                                </td>

                                <td style="border:1px solid #ccc;padding:8px;">
                                    <span t-field="o.partner_id"/>
                                </td>

                            </tr>

                            <tr>

                                <td style="border:1px solid #ccc;padding:8px;">
                                    طريقة الدفع
                                </td>

                                <td style="border:1px solid #ccc;padding:8px;">
                                    <span t-field="o.journal_id"/>
                                </td>

                            </tr>

                        </table>

                        <!-- Amount -->

                        <div style="
                             background:#8b1e2d;
                             color:white;
                             padding:8px;
                             margin-bottom:10px;">

                            تفاصيل المبلغ

                        </div>

                        <table style="
                               width:100%;
                               border-collapse:collapse;
                               margin-bottom:20px;">

                            <tr>

                                <td style="border:1px solid #ccc;padding:8px;">
                                    المبلغ المصروف
                                </td>

                                <td style="border:1px solid #ccc;padding:8px;">
                                    <span t-field="o.amount"/>
                                </td>

                            </tr>

                        </table>

                        <!-- Notes -->

                        <div style="
                             background:#8b1e2d;
                             color:white;
                             padding:8px;
                             margin-bottom:10px;">

                            ملاحظات

                        </div>

                        <div style="
                             border:1px solid #ccc;
                             min-height:70px;
                             padding:10px;
                             margin-bottom:30px;">
                             <span t-field="o.memo"/>

                            

                        </div>

                        <!-- Signatures -->

                        <table style="width:100%;">

                            <tr>

                                <td style="text-align:center;">
                                    <strong>المعتمد</strong>
                                    <br/><br/><br/>
                                </td>

                                <td style="text-align:center;">
                                    <strong>المستلم</strong>
                                    <br/><br/><br/>
                                </td>

                            </tr>

                        </table>

                    </div>

                </t>

            </t>

        </t>

    </template>

</odoo>