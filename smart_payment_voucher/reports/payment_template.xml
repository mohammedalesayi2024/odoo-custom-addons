<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="payment_voucher_template">

        <t t-call="web.html_container">

            <t t-foreach="docs" t-as="o">

                <t t-call="web.basic_layout">

                    <div class="page"
                       style="direction:rtl;
                            font-family:Arial;
                            margin-top:0px;
                            padding-top:0px;">

                        <!-- Header -->

                        <div style="
                            background:#8b1e2d;
                            color:white;
                            padding:15px;
                            text-align:center;
                            border-radius:10px;
                            margin-bottom:20px;">

                            <h2 style="margin:0;">
                                سند صرف
                            </h2>

                        </div>

                        <!-- Voucher Info -->

                        <table style="
                               width:100%;
                               border-collapse:collapse;
                               margin-bottom:20px;">

                            <tr>

                                <td style="border:1px solid #ccc;padding:8px;">
                                    <strong>رقم السند</strong>
                                </td>

                                <td style="border:1px solid #ccc;padding:8px;">
                                    <span t-field="o.name"/>
                                </td>

                                <td style="border:1px solid #ccc;padding:8px;">
                                    <strong>التاريخ</strong>
                                </td>

                                <td style="border:1px solid #ccc;padding:8px;">
                                    <span t-field="o.date"/>
                                </td>

                            </tr>

                        </table>

                        <!-- Beneficiary -->

                        <div style="
                             background:#8b1e2d;
                             color:white;
                             padding:8px;
                             margin-bottom:10px;">

                            بيانات المستفيد

                        </div>

                        <table style="
                               width:100%;
                               border-collapse:collapse;
                               margin-bottom:20px;">

                            <tr>

                                <td style="border:1px solid #ccc;padding:8px;">
                                    المستفيد
                                </td>

                                <td style="border:1px solid #ccc;padding:8px;">
                                    <span t-field="o.partner_id"/>
                                </td>

                            </tr>

                            <tr>

                                <td style="border:1px solid #ccc;padding:8px;">
                                    طريقة الدفع
                                </td>

                                <td style="border:1px solid #ccc;padding:8px;">
                                    <span t-field="o.payment_method_line_id"/>
                                </td>

                            </tr>

                        </table>

                        <!-- Amount -->

                        <div style="
                             background:#8b1e2d;
                             color:white;
                             padding:8px;
                             margin-bottom:10px;">

                            تفاصيل المبلغ

                        </div>

                        <table style="
                               width:100%;
                               border-collapse:collapse;">

                            <tr>

                                <td style="border:1px solid #ccc;padding:8px;">
                                    المبلغ المصروف
                                </td>

                                <td style="border:1px solid #ccc;padding:8px;">
                                    <span t-field="o.amount"/>
                                </td>

                            </tr>

                        </table>

                        <br/><br/><br/>

                        <table style="width:100%;">

                            <tr>

                                <td style="text-align:center;">
                                    <strong>المعتمد</strong>
                                </td>

                                <td style="text-align:center;">
                                    <strong>التوقيع</strong>
                                </td>

                            </tr>

                        </table>

                    </div>

                </t>

            </t>

        </t>

    </template>

</odoo>