<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="payment_voucher_template">

        <t t-call="web.html_container">

            <t t-foreach="docs" t-as="o">
             <t t-set="is_ar" t-value="o.env.user.lang and o.env.user.lang.startswith('ar')"/>  
                <t t-call="web.basic_layout">

                    <div class="page"
                       t-att-style="'direction:rtl;font-family:Tahoma;margin-top:0px;' if is_ar else 'direction:ltr;font-family:Tahoma;margin-top:0px;'">

                        <!-- Company Header -->

                        <table style="
                               width:100%;
                               border:1px solid #dcdcdc;
                               border-collapse:collapse;
                               margin-bottom:20px;">

                            <tr>

                                <td style="
                                    width:20%;
                                    text-align:center;
                                    vertical-align:top;
                                    padding:3px;
                                    border-left:1px solid #dcdcdc;">

                                    <img t-if="o.company_id.logo"
                                         t-att-src="image_data_uri(o.company_id.logo)"
                                         style="max-height:70px; max-width:90px; margin-top:-5px;"/>

                                </td>

                                <td style="
                                    width:85%;
                                    text-align:right;
                                    padding:5px;">

                                    <h2 style="
                                        margin:0;
                                        color:#1f2d3d;">

                                        <span t-field="o.company_id.name"/>

                                    </h2>

                                    <div style="margin-top:8px;">
                                        <t t-if="is_ar">جدة - المملكة العربية السعودية</t>
                                        <t t-else="">Jeddah - Saudi Arabia</t>
                                    </div>

                                    <div t-if="o.company_id.vat">
                                        
                                        <t t-if="is_ar">الرقم الضريبي</t>   
                                        <t t-else="">VAT Number</t>
                                        <span t-field="o.company_id.vat"/>
                                    </div>

                                    <div t-if="o.company_id.phone">
                                        
                                        <t t-if="is_ar">هاتف</t>
                                        <t t-else="">Phone</t>

                                        <span t-field="o.company_id.phone"/>
                                    </div>

                                    <div t-if="o.company_id.email">
                                        
                                        <t t-if="is_ar">بريد</t>
                                        <t t-else="">Email</t>
                                        <span t-field="o.company_id.email"/>
                                    </div>

                                </td>

                            </tr>

                        </table>

                        <!-- Voucher Info -->

                        <table style="width:100%; border-collapse:collapse; margin-bottom:20px;">

                            <tr>

                                <td style="width:60%;">

                                    <div style="
                                        background:#8b1e2d;
                                        color:white;
                                        text-align:center;
                                        font-size:24px;
                                        font-weight:bold;
                                        padding:20px;
                                        height:50px;
                                        border-radius:3px;">
                                        <t t-if="is_ar">سند صرف</t>
                                        <t t-else="">Payment Voucher</t>

                                    </div>

                                </td>

                                <td style="width:40%;">

                                    <table style="
                                           width:100%;
                                           border-collapse:collapse;">

                                        <tr>

                                            <td style="border:1px solid #ccc;padding:8px;">
                                                
                                                
                                               <t t-if="is_ar">رقم السند</t>
                                               <t t-else="">Voucher Number</t>
                                            </td>

                                            <td style="border:1px solid #ccc;padding:8px;">
                                                <span t-field="o.name"/>
                                            </td>

                                        </tr>

                                        <tr>

                                            <td style="border:1px solid #ccc;padding:8px;">
                                                
                                                
                                              <t t-if="is_ar">التاريخ</t>
                                              <t t-else="">Date</t>
                                            </td>

                                            <td style="border:1px solid #ccc;padding:8px;">
                                                <span t-field="o.date"/>
                                            </td>

                                        </tr>

                                    </table>

                                </td>

                            </tr>

                        </table>

                        <hr style="border:1px solid #e5e5e5; margin:10px 0 20px 0;"/>

                        <!-- Beneficiary -->

                        <div style="
                             background:#8b1e2d;
                             color:white;
                             padding:8px;
                             margin-bottom:10px;">

                            <t t-if="is_ar">بيانات المستفيد</t>
                            <t t-else="">Beneficiary Details</t>

                        </div>

                        <table style="
                               width:100%;
                               border-collapse:collapse;
                               margin-bottom:20px;">

                            <tr>

                                <td style="border:1px solid #ccc;padding:8px;">
                                    
                                    <t t-if="is_ar">المستفيد</t>
                                    <t t-else="">Beneficiary Details</t>
                                </td>

                                <td style="border:1px solid #ccc;padding:8px;">
                                    <span t-field="o.partner_id"/>
                                </td>

                            </tr>

                            <tr>

                                <td style="border:1px solid #ccc;padding:8px;">
                                    
                                    <t t-if="is_ar">طريقة الدفع</t>
                                    <t t-else="">Payment Method</t>
                                </td>

                                <td style="border:1px solid #ccc;padding:8px;">
                                    <span t-field="o.journal_id"/>
                                </td>

                            </tr>

                        </table>

                        <!-- Amount -->

                        <div style="
                             background:#8b1e2d;
                             color:white;
                             padding:8px;
                             margin-bottom:10px;">

                        
                            <t t-if="is_ar">تفاصيل المبلغ</t>
                            <t t-else="">Amount Details</t>

                        </div>

                        <table style="
                               width:100%;
                               border-collapse:collapse;
                               margin-bottom:20px;">

                            <tr>

                                <td style="border:1px solid #ccc;padding:8px;">
                                    
                                    <t t-if="is_ar">المبلغ المصروف</t>
                                    <t t-else="">Amount</t>
                                </td>

                                <td style="border:1px solid #ccc;padding:8px;">
                                    <span t-field="o.amount"/>
                                </td>

                            </tr>

                            <tr>

                                <td style="border:1px solid #ccc;padding:8px;">
                                    
                                    <t t-if="is_ar">المبلغ كتابة</t>
                                    <t t-else="">Amount in Words</t>        
                                </td>

                                <td style="border:1px solid #ccc;padding:8px;">
                                    <span t-field="o.amount_in_words"/>
                                </td>

                            </tr>

                        </table>

                        <!-- Notes -->

                        <div style="
                             background:#8b1e2d;
                             color:white;
                             padding:8px;
                             margin-bottom:10px;">

                            
                            <t t-if="is_ar">ملاحظات</t>
                            <t t-else="">Notes</t>

                        </div>

                        <div style="
                             border:1px solid #ccc;
                             min-height:70px;
                             padding:10px;
                             margin-bottom:30px;">

                            <span t-field="o.memo"/>

                        </div>

                        <!-- Signatures -->

                        <table style="width:100%;">

                            <tr>

                                <td style="text-align:center;">

                                    
                                    <t t-if="is_ar">المعتمد</t>
                                    <t t-else="">Approver</t>

                                    <br/>
                                    <br/>
                                    <br/>

                                </td>

                                <td style="text-align:center;">

                                    <t t-if="is_ar">المستلم</t>
                                    <t t-else="">Recipient</t>          

                                    <br/>
                                    <br/>
                                    <br/>

                                </td>

                            </tr>

                        </table>

                    </div>

                </t>

            </t>

        </t>

    </template>

</odoo>