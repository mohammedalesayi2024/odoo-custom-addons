<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_account_payment_form_voucher"
            model="ir.ui.view">

        <field name="name">account.payment.form.voucher</field>
        <field name="model">account.payment</field>

        <field name="inherit_id"
               ref="account.view_account_payment_form"/>

        <field name="arch" type="xml">

            <xpath expr="//header"
                   position="inside">

                <button
                    name="action_print_receipt_voucher"
                    type="object"
                    string="Receipt Voucher"
                    class="btn-primary"/>

                <button
                    name="action_print_payment_voucher"
                    type="object"
                    string="Payment Voucher"
                    class="btn-secondary"/>

            </xpath>

        </field>

    </record>

</odoo>